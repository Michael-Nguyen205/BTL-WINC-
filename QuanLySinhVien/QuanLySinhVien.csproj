    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.Data.SqlClient" Version="4.8.6" />
    <PackageReference Include="System.Configuration.ConfigurationManager" Version="8.0.0" />
  </ItemGroup>

  <ItemGroup>
    <Compile Update="FrmDangNhap.cs">
      <SubType>Form</SubType>
    </Compile>
    <Compile Update="FrmDangNhap.Designer.cs">
      <DependentUpon>FrmDangNhap.cs</DependentUpon>
    </Compile>
    <Compile Update="FrmDanhSach.cs">
      <SubType>Form</SubType>
    </Compile>
    <Compile Update="FrmDanhSach.Designer.cs">
      <DependentUpon>FrmDanhSach.cs</DependentUpon>
    </Compile>
  </ItemGroup>

</Project>
